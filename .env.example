#Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# GCP project
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# Cloud Storage (bucket created by setup_gcp.sh: <project-id>-dataflow)
GCS_BUCKET=your-gcp-project-id-dataflow

# Pub/Sub
PUBSUB_TOPIC=traffic-events
PUBSUB_SUBSCRIPTION=traffic-events-sub

# BigQuery
BQ_DATASET=traffic_analytics

# Service account key (downloaded from GCP Console → IAM → Service Accounts)
# Path to the JSON key file for dataflow-runner@<project>.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/dataflow-runner-key.json
